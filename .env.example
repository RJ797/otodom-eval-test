# Copy this file to .env and fill in real values. .env is gitignored and is
# never read by the assistant. Secrets are read from the environment at runtime.

# --- Gemini (runner) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Replicate / Flux (runner) ---
# Model is fixed in code: black-forest-labs/flux-2-klein-9b
REPLICATE_API_TOKEN=

# --- AWS S3 + CDN (runner) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
S3_BUCKET=magicbox
S3_ROOT_PREFIX=otodom-image-eval
CDN_BASE_URL=https://magicbox.styldod.com

# --- MongoDB (runner + Vercel scoring app) ---
MONGODB_URI=
MONGODB_DB=otodom_image_eval

# --- Pricing (USD) ---
# Gemini cost is computed from token counts (per 1M). Image output is billed much
# higher than text output, so it is priced separately. Defaults below are the
# Gemini 3.1 Flash Image STANDARD rates. Flux uses a flat per-image rate.
GEMINI_PRICE_INPUT_PER_1M=0.50
GEMINI_PRICE_TEXT_OUTPUT_PER_1M=3.00
GEMINI_PRICE_IMAGE_OUTPUT_PER_1M=60.00
FLUX_COST_PER_IMAGE=0.015

# --- Runner behavior ---
RUN_CONCURRENCY=4
RUN_MAX_RETRIES=2

# --- Local playground server (optional) ---
HOST=127.0.0.1
PORT=8000
